# Example environment variables for Vite
# Rename to .env and update values for local development (do NOT commit real secrets)

# Public (client) variables must start with VITE_
VITE_API_URL=https://api.example.com
VITE_API_KEY=your_api_key_here

# Server-only secrets should NOT be exposed to the client and therefore
# should be kept out of the repo (in a real project, do NOT prefix with VITE_)
# EXAMPLE_SERVER_SECRET=replace_with_real_secret
